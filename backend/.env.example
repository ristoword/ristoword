# Ristoword – environment variables
# Copy to .env and fill in values

# Required: session signing secret (use a long random string)
SESSION_SECRET=your-session-secret-min-32-chars

# Smoke test (npm test): carica l’app in memoria; SESSION_SECRET deve essere valida anche in CI.

# Optional: server port (default 3000 se PORT assente)
# Esempio copia locale su porta dedicata: PORT=3001
# PORT=3000

# Optional: environment (development | production)
# NODE_ENV=production

# URL pubblico (senza slash finale). Usa uno tra questi (check avvio in server.js / validateConfig):
# PUBLIC_APP_URL=https://tuodominio.com
# BASE_URL=https://tuodominio.com
# (APP_URL è ancora supportato sotto, stesso ruolo)

# Optional: app version for health endpoint
# RISTOWORD_VERSION=1.0.0

# Optional: base path if app is served under subpath (e.g. /ristoword)
# BASE_PATH=

# Optional: data directory override (default: ./data)
# DATA_PATH=./data

# OpenAI (for POST /api/ai/query – production AI with structured JSON)
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4o-mini

# =======================
#  SUPER ADMIN (private)
# =======================
# Username fissa per l'accesso alla super-admin dashboard
SUPER_ADMIN_USERNAME=superadmin

# Password iniziale (obbligatoria al primo accesso se SUPER_ADMIN_FORCE_PASSWORD_CHANGE=true)
SUPER_ADMIN_PASSWORD=metti-password-forte

# Se true: al primo login forzerà il cambio password. Dopo il cambio rimane sbloccata.
SUPER_ADMIN_FORCE_PASSWORD_CHANGE=true

# IMPORTANTE per PRODUZIONE (online): imposta le stesse variabili nelle env
# del tuo hosting (Railway, Heroku, ecc.) per accedere a:
#   https://tuodominio.com/super-admin-login

# =======================
#  URL PUBBLICO + EMAIL (trial / Stripe → owner-activate)
# =======================
# URL base senza slash finale: usata per link assoluti nelle email (codice attivazione).
# APP_URL=https://tuodominio.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Ristoword <noreply@tuodominio.com>"
#
# Origini browser ammesse per CORS (Gestione Semplificata su altra porta/dominio), separate da virgola
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# --- GS batch codici (master su Gestione Semplificata) ---
# Segreto condiviso RW ↔ GS per import mirror e webhook
# GS_RW_SYNC_SECRET=genera-stringa-lunga-random
# URL su GS che riceve notifica "codice attivato" da Ristoword (implementare lato GS)
# GS_WEBHOOK_ACTIVATION_URL=https://www.gestionesemplificata.com/api/licenses/rw/activation-used
# Opzionale: stesso valore di GS_RW_SYNC_SECRET, inviato come header X-RW-Sync-Secret
# GS_RW_SHARED_SECRET=
#
# Allineamento RW → GS (dopo "Genera codici" in Super Admin e dopo pagamento Stripe):
# POST body { source:"ristoword", codes:[{code,status,assignedEmail,expiresAt,source},...] }
# GS_CODES_UPSERT_URL=https://www.gestionesemplificata.com/api/licenses/rw/codes-upsert
# Dopo Stripe: codice assegnato al cliente (stesso validate DB)
# GS_CODES_RESERVE_URL=https://www.gestionesemplificata.com/api/licenses/rw/codes-reserve
#
# Solo sviluppo locale senza validate GS: accetta codici solo dal mirror RW
# GS_VALIDATE_USE_MIRROR=true

# =======================
#  Stripe (checkout live + webhook → tenant/licenza DB)
# =======================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID abbonamento (alias accettato: STRIPE_PRICE_RISTOWORD_MONTHLY)
# STRIPE_PRICE_ID=price_...
# URL pubblico senza slash finale (success/cancel checkout)
# BASE_URL=http://localhost:3001
# Opzionale: disattiva creazione automatica tenant+licenza se manca restaurantId in metadata
# STRIPE_AUTO_PROVISION_DB=false

# Flusso gestionale (mock checkout in questo repo):
# 1) POST /api/checkout { restaurantId, mode:"trial", customerEmail }
# 2) POST /api/checkout/mock/complete { sessionId, outcome:"paid" }
#    → crea licenza + codice, opzionale email, risposta con activationCode e ownerActivateUrl
# 3) Cliente apre /owner-activate, inserisce codice e crea password → onboarding owner
